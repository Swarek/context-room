{
  "name": "context-room",
  "version": "0.2.0",
  "description": "Local-first documentation control room for AI-assisted projects.",
  "type": "module",
  "homepage": "https://www.npmjs.com/package/context-room",
  "bin": {
    "context-room": "bin/context-room.mjs"
  },
  "exports": {
    ".": "./src/context_room.mjs"
  },
  "files": [
    "bin/",
    "scripts/",
    "src/",
    "docs/",
    "examples/",
    "schemas/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/context-room.mjs start",
    "init": "node bin/context-room.mjs init",
    "doctor": "node bin/context-room.mjs doctor",
    "test": "node --check src/context_room.mjs && node --check bin/context-room.mjs && node --check scripts/update-context-rooms.mjs && node --test test/*.test.mjs",
    "package:privacy": "node scripts/check-package-privacy.mjs",
    "prepack": "npm run package:privacy",
    "update:rooms": "node scripts/update-context-rooms.mjs",
    "pack:dry-run": "npm pack --dry-run"
  },
  "keywords": [
    "ai-agent",
    "context",
    "documentation",
    "docs",
    "skills",
    "agent-loops",
    "local-first",
    "review-queue",
    "developer-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "ws": "^8.21.1"
  },
  "engines": {
    "node": ">=20"
  }
}
