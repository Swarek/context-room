        },
        "effectiveText": {
          "$ref": "#/$defs/nullableString"
        },
        "targetPattern": {
          "$ref": "#/$defs/nullableString"
        },
        "sourceTargetId": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
