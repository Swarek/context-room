        {
          "type": "null"
        }
      ]
    },
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "overrideConflict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "sourceTargetId"
