{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unpkg.com/context-room@latest/schemas/codex-prompt-catalog-v1.schema.json",
  "title": "Codex prompt catalog v1",
  "description": "Strict schema for prompt-overrides/catalog.json and immutable runtime catalog snapshots.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runtimeVersion",
    "catalogRevision",
    "groups"
