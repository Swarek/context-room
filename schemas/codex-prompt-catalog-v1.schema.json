      "items": {
        "$ref": "#/$defs/group"
      }
    }
  },
  "$defs": {
    "hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "nullableHash": {
      "anyOf": [
        {
          "$ref": "#/$defs/hash"
