        "editable": {
          "type": "boolean"
        },
        "runtimeStatus": {
          "enum": [
            "active",
            "available_local_only",
            "bundled",
            "cached",
            "catalogued",
            "configured",
            "selectable",
            "dormant",
            "override_conflict",
            "pattern",
            "shadowed_by_explicit_config",
            "shadowed_by_session_history",
            "personality_dependent",
            "protected",
            "server_owned"
          ]
        },
        "officialHash": {
          "$ref": "#/$defs/nullableHash"
        },
        "officialText": {
          "$ref": "#/$defs/nullableString"
        },
        "effectiveHash": {
