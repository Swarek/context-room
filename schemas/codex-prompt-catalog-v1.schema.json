            "config_shadowed",
            "session_history",
            "dynamic_assembly",
            "enforcement_coupled",
            "security_critical",
            "contract_coupled",
            "state_assembled",
            "protocol_coupled",
            "privacy_sensitive",
            "dynamic_capability",
            "authority_sensitive",
            "runtime_generated",
            "lifecycle_managed",
            "history_semantics",
            "executable_contract",
            "configurable_elsewhere",
